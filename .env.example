# Copy this file to .env (same directory as docker-compose.yml) and fill in real values.
# .env is gitignored — never commit the actual file with real secrets in it.

# HMAC signing key for JWTs, 32+ random characters. The app refuses to start without this.
# Generate one with: openssl rand -base64 48
JWT_SECRET=

# MongoDB Atlas connection string, including the database name.
# Format: mongodb+srv://<user>:<password>@<cluster-host>/<database-name>?retryWrites=true&w=majority
MONGODB_URI=

# First admin account — ONLY used once, the very first time the app starts against an empty
# `users` collection. Safe (and recommended) to delete these two lines once you've logged in
# with them and set a real password — see DEPLOYMENT.md's "First admin account" section.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Only needed if pulling published images (see DEPLOYMENT.md's "Running via docker-compose").
# Not used when building from source on the server — omit both in that case.
BACKEND_TAG=latest
FRONTEND_TAG=latest
